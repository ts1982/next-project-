generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// RBAC: Role-Based Access Control
// ---------------------------------------------------------------------------

/// パーミッションのスコープ
///   ALL — リソース全体に対する操作権限
///   OWN — 自己所有リソースに限定した操作権限
enum PermissionScope {
  ALL
  OWN
}

/// ロール（管理者用）
model Role {
  id          String   @id @default(cuid())
  name        String   @unique @db.VarChar(50)
  description String?  @db.VarChar(200)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  admins          Admin[]
  rolePermissions RolePermission[]

  @@map("roles")
}

/// パーミッション定義（リソース × アクション）
model Permission {
  id          String   @id @default(cuid())
  resource    String   @db.VarChar(50)
  action      String   @db.VarChar(50)
  description String?  @db.VarChar(200)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

/// ロールとパーミッションの中間テーブル（scope 付き）
model RolePermission {
  id           String          @id @default(cuid())
  roleId       String
  permissionId String
  scope        PermissionScope @default(ALL)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ---------------------------------------------------------------------------
// Admin（管理者）
// ---------------------------------------------------------------------------

/// システム管理者（旧 User）
model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  roleId    String
  image     String?
  timezone  String?  @db.VarChar(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  role               Role                @relation(fields: [roleId], references: [id])
  adminNotifications AdminNotification[]

  @@map("admins")
}

// ---------------------------------------------------------------------------
// User（通知受信者）
// ---------------------------------------------------------------------------

/// 一般ユーザー（通知受信者）
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  timezone  String?  @db.VarChar(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notifications            Notification[]
  adminNotificationTargets AdminNotificationTarget[]

  @@map("users")
}

// ---------------------------------------------------------------------------
// Notifications
// ---------------------------------------------------------------------------

/// 通知種別
enum NotificationType {
  SYSTEM
  INFO
  WARNING
  PROMOTION
}

/// 通知の配信対象種別
enum NotificationTargetType {
  ALL      // 全ユーザー対象
  SPECIFIC // 特定ユーザー対象
}

/// 管理者が作成する通知マスター
model AdminNotification {
  id               String                 @id @default(cuid())
  createdByAdminId String
  title            String                 @db.VarChar(200)
  body             String
  type             NotificationType       @default(INFO)
  targetType       NotificationTargetType @default(ALL)
  scheduledAt      DateTime?
  deliveredAt      DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  createdBy     Admin                     @relation(fields: [createdByAdminId], references: [id])
  targets       AdminNotificationTarget[]
  notifications Notification[]

  @@index([scheduledAt])
  @@index([deliveredAt])
  @@map("admin_notifications")
}

/// SPECIFIC ターゲット指定テーブル
model AdminNotificationTarget {
  id                  String @id @default(cuid())
  adminNotificationId String
  userId              String

  adminNotification AdminNotification @relation(fields: [adminNotificationId], references: [id], onDelete: Cascade)
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([adminNotificationId, userId])
  @@map("admin_notification_targets")
}

/// ユーザー受信箱
model Notification {
  id                  String           @id @default(cuid())
  userId              String
  adminNotificationId String?
  title               String           @db.VarChar(200)
  body                String
  type                NotificationType @default(INFO)
  isRead              Boolean          @default(false)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  adminNotification AdminNotification? @relation(fields: [adminNotificationId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}

// ---------------------------------------------------------------------------
// Business Domain
// ---------------------------------------------------------------------------

model Store {
  id            Int       @id @default(autoincrement())
  name          String
  description   String?
  address       String
  phone         String?
  email         String?
  publishedAt   DateTime?
  unpublishedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([publishedAt])
  @@index([unpublishedAt])
  @@map("stores")
}
